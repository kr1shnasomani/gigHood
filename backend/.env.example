# Supabase Settings
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key

# External Signals APIs
OPENWEATHER_API_KEY=your_openweather_api_key
CPCB_API_KEY=your_cpcb_api_key

# Payment Integrations (Razorpay Sandbox)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Notifications (Firebase)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# AI Chat Assistant
OPENROUTER_API_KEY=your_openrouter_api_key
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL_NAME=qwen/qwen3-32b
OPENROUTER_MODEL_NAME=google/gemma-3-27b-it
OPENROUTER_HTTP_REFERER=https://gighood.app
OPENROUTER_APP_TITLE=gigHood Gig Copilot

# ML (Risk Profiler)
RISK_PROFILER_MODEL_JSON_PATH=backend/ml/risk_profiler.json
RISK_PROFILER_MODEL_PKL_PATH=backend/ml/risk_profiler.pkl
RISK_PROFILER_DATASET_PATH=dataset/synthetic_training_data.csv
AUTO_TRAIN_RISK_MODEL_ON_STARTUP=true

# Security
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated frontend origins)
BACKEND_CORS_ORIGINS=http://localhost:3000,https://gighood.vercel.app

# Scheduler reliability (helps avoid overlap + skipped runs)
ENABLE_SCHEDULER=true
SIGNAL_JOB_CRON_MINUTE=*/10
DCI_JOB_CRON_MINUTE=1,11,21,31,41,51
SCHEDULER_MAX_INSTANCES=1
SCHEDULER_COALESCE=true
SCHEDULER_MISFIRE_GRACE_SECONDS=300
SCHEDULER_HEX_LIMIT=500

# Supabase network retry for transient disconnections
SUPABASE_RETRY_ATTEMPTS=3
SUPABASE_RETRY_BACKOFF_SECONDS=0.35
